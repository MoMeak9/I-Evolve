{
  "name": "@i-evolve/mcp-server",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "i-evolve-mcp-server": "./dist/server.js"
  },
  "exports": {
    ".": "./src/server.ts"
  },
  "scripts": {
    "build": "tsup src/server.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@i-evolve/core": "workspace:*",
    "@i-evolve/daemon": "workspace:*",
    "@i-evolve/storage": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
