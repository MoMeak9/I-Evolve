{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm",
            "args": ["-C", "${IEVOLVE_HOME}", "exec", "tsx", "apps/cli/src/index.ts", "inject", "--format", "markdown"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm",
            "args": ["-C", "${IEVOLVE_HOME}", "exec", "tsx", "apps/cli/src/index.ts", "observe", "--phase", "post_tool_use", "--source", "claude-code"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm",
            "args": ["-C", "${IEVOLVE_HOME}", "exec", "tsx", "apps/cli/src/index.ts", "session", "finalize", "--auto-evolve"]
          }
        ]
      }
    ]
  }
}
