{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://i-evolve.dev/schemas/observation.schema.json",
  "title": "Observation",
  "description": "I-Evolve Observation event schema",
  "type": "object",
  "required": ["id", "timestamp", "session_id", "source", "phase", "summary", "status", "sensitivity"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "repo_id": { "type": "string" },
    "project_id": { "type": "string" },
    "cwd_hash": { "type": "string" },
    "source": {
      "type": "string",
      "enum": ["claude-code", "codex", "cursor", "cli", "mcp"]
    },
    "phase": {
      "type": "string",
      "enum": ["session_start", "pre_tool_use", "post_tool_use", "stop", "manual"]
    },
    "tool": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "files_touched": { "type": "array", "items": { "type": "string" } },
    "commands": { "type": "array", "items": { "type": "string" } },
    "risk_flags": { "type": "array", "items": { "type": "string" } },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "blocked", "unknown"]
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "sensitive"]
    },
    "raw_ref": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["local_encrypted_file", "none"] },
        "path_hash": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" }
      },
      "required": ["type"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
